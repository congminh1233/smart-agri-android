# Tránh lộ Key bảo mật (Bắt buộc)
*.jks
*.keystore

# Các thư mục build và cache sinh ra trong quá trình chạy
build/
.gradle/
/captures/
.externalNativeBuild/
.cxx/

# Cấu hình máy cá nhân (Không được đẩy lên mạng)
local.properties

