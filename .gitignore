*.iml
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml

# File rác của hệ điều hành macOS (Nếu sau này có người dùng Mac tải code)
.DS_Store